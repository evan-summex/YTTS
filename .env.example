# YTT Summarizer — environment variable template
#
# HOW TO USE:
#   1. Copy this file to a new file named  .env   (cp .env.example .env)
#   2. Replace the placeholder values below with your real keys.
#   3. NEVER commit .env — it's git-ignored on purpose. Only THIS template
#      (.env.example, with fake values) belongs in the repo.
#
# Your backend reads these at runtime via python-dotenv + os.environ.

# Supadata API key — sent to Supadata as the  x-api-key  request header.
# Get one at https://supadata.ai/  (free tier: 100 requests/month).
SUPADATA_API_KEY=your-supadata-api-key-here

# Anthropic API key — used for the Claude summarization call.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
